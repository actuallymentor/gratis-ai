{
  "name": "gratisai",
  "version": "0.3.1",
  "description": "Privacy-first, offline-capable local LLM chat application",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build && electron-builder",
    "test": "playwright test --config=tests/playwright.config.js",
    "test:ui": "playwright test --ui --config=tests/playwright.config.js",
    "test:headed": "playwright test --headed --config=tests/playwright.config.js",
    "lint": "eslint --fix src",
    "postinstall": "node scripts/ensure_platform_deps.js && node scripts/copy_wasm.js && node scripts/generate_speedtest_files.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@wllama/wllama": "^2.3.7",
    "electron-updater": "^6.8.3",
    "idb": "^8.0.1",
    "less-lazy": "^0.0.2",
    "lucide-react": "^0.468.0",
    "node-llama-cpp": "^3.15.1",
    "parakeet.js": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "styled-components": "^6.1.13",
    "use-query-params": "^2.2.1",
    "uuid": "^9.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-react": "^4.3.4",
    "airier": "^0.1.1",
    "electron": "^40.4.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  }
}
