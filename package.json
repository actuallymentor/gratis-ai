{
    "name": "gratisai",
    "version": "0.36.1",
    "description": "Privacy-first, offline-capable local LLM chat application",
    "repository": {
        "type": "git",
        "url": "https://github.com/actuallymentor/gratis-ai.git"
    },
    "main": "out/main/main.js",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "dev:electron": "electron-vite dev",
        "build:electron": "electron-vite build && electron-builder",
        "test": "playwright test --config=tests/playwright.config.js",
        "test:ui": "playwright test --ui --config=tests/playwright.config.js",
        "test:headed": "playwright test --headed --config=tests/playwright.config.js",
        "test:unit": "vitest run tests/unit/",
        "lint": "eslint --fix src",
        "postinstall": "node scripts/ensure_platform_deps.js && node scripts/copy_wasm.js && node scripts/generate_speedtest_files.js",
        "prepare": "husky"
    },
    "dependencies": {
        "@fontsource-variable/montserrat": "^5.2.8",
        "@fontsource-variable/nunito": "^5.2.7",
        "@wllama/wllama": "^2.3.7",
        "electron-updater": "^6.8.3",
        "i18next": "^25.8.13",
        "idb": "^8.0.3",
        "less-lazy": "^0.0.2",
        "lucide-react": "^0.575.0",
        "mentie": "^0.5.4",
        "node-llama-cpp": "^3.16.2",
        "parakeet.js": "^1.4.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hot-toast": "^2.6.0",
        "react-i18next": "^16.5.4",
        "react-markdown": "^10.1.0",
        "react-router-dom": "^7.13.1",
        "rehype-highlight": "^7.0.2",
        "remark-gfm": "^4.0.1",
        "styled-components": "^6.3.11",
        "use-query-params": "^2.2.2",
        "uuid": "^13.0.0",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@vitejs/plugin-react": "^5.1.4",
        "airier": "^0.1.1",
        "electron": "^40.6.1",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.3",
        "husky": "^9.1.7",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.0"
    }
}
