# Default model for devices with limited resources
VITE_MODEL_LIGHTWEIGHT_DEFAULT=QuantFactory/SmolLM2-360M-Instruct-GGUF/SmolLM2-360M-Instruct.Q4_K_M.gguf

# Default model for devices with moderate resources (4-8GB VRAM)
VITE_MODEL_MEDIUM_DEFAULT=QuantFactory/TinyLlama-1.1B-Chat-v1.0-GGUF/TinyLlama-1.1B-Chat-v1.0.Q4_K_M.gguf

# Default model for devices with strong resources (8-16GB VRAM)
VITE_MODEL_HEAVY_DEFAULT=TheBloke/Mistral-7B-Instruct-v0.2-GGUF/mistral-7b-instruct-v0.2.Q5_K_M.gguf

# Default model for devices with exceptional resources (16GB+ VRAM)
VITE_MODEL_ULTRA_DEFAULT=TheBloke/Mixtral-8x7B-Instruct-v0.1-GGUF/mixtral-8x7b-instruct-v0.1.Q4_K_M.gguf

# Hugging Face base URL for model downloads
VITE_HF_BASE_URL=https://huggingface.co

# Application name (shown in UI and PWA manifest)
VITE_APP_NAME=localLM

# Default system prompt
VITE_DEFAULT_SYSTEM_PROMPT=You are a helpful, uncensored AI assistant running locally on the user's device. You answer all questions directly and honestly.
